---
const faqs = [
  {
    question: "How long does a benchmark run take?",
    answer:
      "Core suite (200 questions, 30 samples each) takes about 1 hour. Full suite (684+ questions) takes about 6 hours. Cost depends on your provider.",
  },
  {
    question: "Can I benchmark a closed-source model?",
    answer:
      "Yes. SynthBench works with any model that accepts text prompts. Use the provider adapter interface or the OpenRouter integration.",
  },
  {
    question: "How are scores validated?",
    answer:
      "CI recomputes all aggregate scores from your per-question data. If reported scores don't match recomputed scores, the PR is rejected.",
  },
  {
    question: "Can I submit results from my own conditioning or persona approach?",
    answer:
      "Yes. Include your prompt template and any conditioning metadata. The leaderboard shows provider and configuration.",
  },
  {
    question: "What datasets can I benchmark against?",
    answer:
      "OpinionsQA (684 questions, US), SubPOP (3,362 questions, 22 US subpopulations), GlobalOpinionQA (2,556 questions, 138 countries).",
  },
];
---

<section class="w-full max-w-4xl mx-auto py-12" id="faq">
  <h2
    class="text-2xl font-bold tracking-tight text-text dark:text-text-dark mb-2"
  >
    FAQ
  </h2>
  <p class="text-muted mb-8 max-w-2xl">
    Common questions about running benchmarks and submitting results.
  </p>

  <div class="space-y-3">
    {
      faqs.map((faq) => (
        <details class="group rounded-lg border border-muted/20 bg-surface dark:bg-surface-dark">
          <summary class="flex cursor-pointer items-center justify-between p-5 text-base font-semibold text-text dark:text-text-dark">
            {faq.question}
            <svg
              class="size-5 shrink-0 text-muted transition-transform group-open:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 8.25l-7.5 7.5-7.5-7.5"
              />
            </svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-muted">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</section>
