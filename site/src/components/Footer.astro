---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-muted/20 mt-16">
  <div class="mx-auto max-w-7xl px-6 py-8 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-x-6 text-sm text-muted">
        <a
          href="https://github.com/DataViking-Tech/synthbench"
          class="hover:text-text dark:hover:text-text-dark transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >GitHub</a>
        <a
          href="#about"
          class="hover:text-text dark:hover:text-text-dark transition-colors"
        >About</a>
        <a
          href="#citation"
          class="hover:text-text dark:hover:text-text-dark transition-colors"
        >Cite</a>
      </div>
      <p class="text-xs text-muted">
        &copy; {currentYear} DataViking-Tech. SynthBench is open source.
      </p>
    </div>
  </div>
</footer>
